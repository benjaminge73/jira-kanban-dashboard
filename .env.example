# ──────────────────────────────────────────────────────────────────────────────
# Kanban mAIster — environment configuration
#
# ALL variables are optional. With no .env file the app runs in DEMO MODE with
# deterministic mock data (zero configuration required).
#
# LIVE MODE is enabled when ALL FIVE required variables below are set. The app
# then fetches tickets and status transitions from your Jira Cloud instance.
# ──────────────────────────────────────────────────────────────────────────────

# ── Required for live mode ────────────────────────────────────────────────────

# Your Jira Cloud base URL
#JIRA_BASE_URL=https://your-site.atlassian.net

# Atlassian account email
#JIRA_EMAIL=you@example.com

# API token — create one at https://id.atlassian.com/manage-profile/security/api-tokens
#JIRA_API_TOKEN=your-api-token

# The Jira project to load (single project)
#JIRA_PROJECT_KEY=PROJ

# Custom field holding the "brand" of each issue (select or text field).
# Find field IDs with: curl -u email:token https://your-site.atlassian.net/rest/api/3/field
#JIRA_BRAND_FIELD=customfield_10050

# ── Optional (live mode tuning) ───────────────────────────────────────────────

# Story points field (default: customfield_10016, the most common Jira Cloud default)
#JIRA_STORY_POINTS_FIELD=customfield_10016

# Which Jira time field feeds "actual dev man-days" (seconds / 28800 → 8h days).
# "timespent" (logged work, default) or "timeoriginalestimate" (original estimate).
# When UNSET, the "Planned vs Actual (Dev)" chart and the "Actual / Planned" card
# are hidden in live mode (set it explicitly to show them; demo mode always shows them).
#JIRA_MANDAYS_SOURCE=timespent

# Extra JQL ANDed with the project clause, e.g. restrict to a board or issue types
#JIRA_JQL=issuetype in (Story, Bug, Task)

# Map your real Jira status names to the canonical pipeline used by the KPIs:
# Backlog → In Progress → Review → IT Testing → QA Testing → Business Testing
# → Ready for Release → Done. Keys are case-insensitive. Unmapped statuses pass through.
#JIRA_STATUS_MAPPING={"Code Review":"Review","UAT":"Business Testing","Deployed":"Done"}

# In-memory cache TTL for Jira data, in seconds (default: 300)
#JIRA_CACHE_TTL=300

# Safety cap on the number of issues fetched (default: 2000)
#JIRA_MAX_ISSUES=2000

# Directory for the local JSON store (billed days, planned rates, settings).
# Default: ./data (gitignored)
#DATA_DIR=./data

# ── Admin protection ──────────────────────────────────────────────────────────

# When set, /admin requires this password (HMAC session cookie, 7 days).
# When unset, the admin area stays open — strongly recommended in live mode,
# since admin writes (billed days, planned rates, settings) are otherwise
# unprotected. Use HTTPS in production: the cookie is httpOnly but not Secure.
#ADMIN_PASSWORD=change-me
